## 6. Error Boundaries (Render Failures)

### 6.1 App-Level Error Boundary

**Location:** `app/_layout.tsx` or `App.tsx`

**Purpose:** Catch unexpected render crashes

```tsx
import { Component } from 'react'

class AppErrorBoundary extends Component<
  { children: React.ReactNode },
  { hasError: boolean }
> {
  state = { hasError: false }

  static getDerivedStateFromError() {
    return { hasError: true }
  }

  componentDidCatch(error: Error, errorInfo: React.ErrorInfo) {
    console.error('[App Error Boundary]:', error, errorInfo)
    // Report to Sentry
  }

  render() {
    if (this.state.hasError) {
      return (
        <View className="flex-1 items-center justify-center p-4">
          <Text className="text-xl font-bold mb-2">Something went wrong</Text>
          <Text className="text-gray-600 text-center mb-4">
            We're sorry for the inconvenience. Please restart the app.
          </Text>
          <Button onPress={() => this.setState({ hasError: false })}>
            Try Again
          </Button>
        </View>
      )
    }

    return this.props.children
  }
}
```

---

### 6.2 Feature-Level Error Boundaries

**Location:** `features/<feature>/components/ErrorBoundary.tsx`

**Purpose:** Isolate feature failures

```tsx
class InvitationErrorBoundary extends Component {
  // ... same pattern

  render() {
    if (this.state.hasError) {
      return (
        <View className="p-4">
          <Text>Unable to load invitation details</Text>
          <Button onPress={() => router.back()}>Go Back</Button>
        </View>
      )
    }

    return this.props.children
  }
}

// Wrap feature screens
<InvitationErrorBoundary>
  <InvitationViewScreen />
</InvitationErrorBoundary>
```

