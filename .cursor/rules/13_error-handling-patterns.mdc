## 5. Toast/Snackbar for Transient Errors

### 5.1 Toast Component

**Implementation:**
```tsx
// features/shared/components/Toast.tsx
import { useEffect } from 'react'
import { View, Text, Animated } from 'react-native'

export function Toast({ message, duration = 3000 }: ToastProps) {
  const opacity = useRef(new Animated.Value(0)).current

  useEffect(() => {
    Animated.sequence([
      Animated.timing(opacity, { toValue: 1, duration: 200 }),
      Animated.delay(duration),
      Animated.timing(opacity, { toValue: 0, duration: 200 }),
    ]).start()
  }, [message])

  if (!message) return null

  return (
    <Animated.View
      style={{ opacity }}
      className="absolute bottom-20 self-center bg-gray-900 px-4 py-3 rounded-lg"
    >
      <Text className="text-white">{message}</Text>
    </Animated.View>
  )
}
```

**Usage:**
```typescript
const [toastMessage, setToastMessage] = useState('')

const handleSubmit = async () => {
  const result = await submitRsvp({ input: data })

  if (result.error) {
    setToastMessage(parseGraphQLError(result.error))
  } else {
    setToastMessage('RSVP submitted successfully!')
  }
}

return (
  <>
    <Form onSubmit={handleSubmit} />
    <Toast message={toastMessage} />
  </>
)
```

