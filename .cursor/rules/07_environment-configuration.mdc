## 5. Expo Config (`app.config.ts`)

### 5.1 Structure

```typescript
import { ExpoConfig, ConfigContext } from 'expo/config'

export default ({ config }: ConfigContext): ExpoConfig => {
  const isProduction = process.env.EXPO_PUBLIC_APP_ENV === 'production'

  return {
    ...config,
    name: isProduction ? 'Hestia' : 'Hestia (Dev)',
    slug: 'hestia',
    version: '1.0.0',
    orientation: 'portrait',
    icon: './assets/icon.png',
    userInterfaceStyle: 'automatic',
    splash: {
      image: './assets/splash.png',
      resizeMode: 'contain',
      backgroundColor: '#ffffff',
    },
    ios: {
      bundleIdentifier: isProduction ? 'app.justhestia.ios' : 'app.justhestia.ios.dev',
      supportsTablet: true,
      infoPlist: {
        NSCameraUsageDescription: 'Allow Hestia to access your camera for profile photos',
      },
    },
    android: {
      package: isProduction ? 'app.justhestia.ios' : 'app.justhestia.ios.dev',
      adaptiveIcon: {
        foregroundImage: './assets/adaptive-icon.png',
        backgroundColor: '#ffffff',
      },
    },
    web: {
      favicon: './assets/favicon.png',
      bundler: 'metro',
    },
    plugins: [
      'expo-router',
      [
        'expo-build-properties',
        {
          ios: {
            useFrameworks: 'static',
          },
        },
      ],
    ],
    extra: {
      // Available via Constants.expoConfig.extra
      eas: {
        projectId: 'YOUR_EAS_PROJECT_ID',
      },
    },
  }
}
```

**Key points:**
- Different bundle IDs for dev/production (allows installing both)
- Dynamic app name shows which build you're running
- Access via `Constants.expoConfig`

