## 4. Using GraphQL in Components

### 4.1 Query Pattern

```typescript
import { useInvitation } from '@/features/invitation/api/invitationApi'

export function InvitationViewScreen({ eventId }: { eventId: string }) {
  const { invitation, loading, error } = useInvitation(eventId)

  if (loading) return <LoadingSpinner />
  if (error) return <ErrorMessage error={error} />
  if (!invitation) return <NotFound />

  return (
    <View>
      <Text>{invitation.eventName}</Text>
      <Text>{invitation.eventDate}</Text>
    </View>
  )
}
```

**Rules:**
- Handle loading, error, and empty states explicitly
- Never assume data exists (TypeScript union types enforce this)

---

### 4.2 Mutation Pattern

```typescript
import { useSubmitRsvpMutation } from '@/features/invitation/api/invitationApi'

export function RsvpForm() {
  const [, submitRsvp] = useSubmitRsvpMutation()

  const handleSubmit = async (data: RsvpFormData) => {
    const result = await submitRsvp({ input: data })

    if (result.error) {
      // Show error to user
      alert('Failed to submit RSVP')
      return
    }

    if (result.data?.submitRsvp.success) {
      // Navigate to confirmation screen
      router.push('/rsvp-confirmation')
    }
  }

  return (
    <Form onSubmit={handleSubmit}>
      {/* Form fields */}
    </Form>
  )
}
```

**Rules:**
- Always check `result.error` before accessing `result.data`
- Provide user feedback (success/error messages)
- Handle optimistic updates when appropriate

