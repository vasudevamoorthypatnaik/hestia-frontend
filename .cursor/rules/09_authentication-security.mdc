## 2. Authentication Flows

### 2.1 Login Flow

**Pattern:**
1. User submits credentials (email + password)
2. GraphQL mutation: `login(email, password)`
3. Backend returns tokens (access + refresh)
4. Frontend stores tokens securely
5. Navigate to authenticated area

```typescript
import { useLoginMutation } from '@/__generated__/graphql'
import { setAuthToken, setRefreshToken } from '@/shared/auth/token'
import { router } from 'expo-router'

export function useLogin() {
  const [, loginMutation] = useLoginMutation()

  const login = async (email: string, password: string) => {
    const result = await loginMutation({ email, password })

    if (result.error) {
      // Handle error (show message to user)
      return { success: false, error: result.error.message }
    }

    const { accessToken, refreshToken } = result.data.login

    // Store tokens securely
    await setAuthToken(accessToken)
    await setRefreshToken(refreshToken)

    // Navigate to authenticated area
    router.replace('/dashboard')

    return { success: true }
  }

  return { login }
}
```

---

### 2.2 Token Refresh Flow

**When to refresh:**
- Access token expired (check expiration before requests)
- GraphQL returns `UNAUTHENTICATED` error

**URQL Auth Exchange handles this automatically:**

```typescript
import { authExchange } from '@urql/exchange-auth'
import { getAuthToken, getRefreshToken, setAuthToken, clearAuthTokens } from '@/shared/auth/token'

authExchange(async (utils) => {
  let token = await getAuthToken()

  return {
    addAuthToOperation(operation) {
      if (!token) return operation

      return utils.appendHeaders(operation, {
        Authorization: `Bearer ${token}`,
      })
    },

    didAuthError(error) {
      // Check if error indicates auth failure
      return error.graphQLErrors.some(
        (e) => e.extensions?.code === 'UNAUTHENTICATED'
      )
    },

    async refreshAuth() {
      const refreshToken = await getRefreshToken()

      if (!refreshToken) {
        // No refresh token, redirect to login
        await clearAuthTokens()
        router.replace('/login')
        return
      }

      // Call refresh mutation
      const result = await utils.mutate(RefreshTokenDocument, { refreshToken })

      if (result.data?.refreshToken) {
        token = result.data.refreshToken.accessToken
        await setAuthToken(token)
      } else {
        // Refresh failed, clear tokens and redirect
        await clearAuthTokens()
        router.replace('/login')
      }
    },
  }
})
```

**Benefits:**
- Automatic token refresh
- Transparent to components
- Handles expired tokens gracefully

---

### 2.3 Logout Flow

```typescript
import { clearAuthTokens } from '@/shared/auth/token'
import { useLogoutMutation } from '@/__generated__/graphql'
import { router } from 'expo-router'

export function useLogout() {
  const [, logoutMutation] = useLogoutMutation()

  const logout = async () => {
    // Call backend logout (invalidate tokens)
    await logoutMutation()

    // Clear local tokens
    await clearAuthTokens()

    // Navigate to login
    router.replace('/login')
  }

  return { logout }
}
```

**Why call backend on logout:**
- Invalidate refresh token server-side
- Prevent token reuse
- Audit trail

