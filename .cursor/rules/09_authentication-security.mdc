### 4.3 Magic Link Handling

**Email link:** `https://hestia.com/auth/magic?token=abc123`

**Route:** `app/auth/magic.tsx`

```typescript
import { useEffect } from 'react'
import { useLocalSearchParams, router } from 'expo-router'
import { setAuthToken } from '@/shared/auth/token'

export default function MagicLinkScreen() {
  const { token } = useLocalSearchParams<{ token: string }>()

  useEffect(() => {
    if (token) {
      validateMagicToken(token).then(async ({ accessToken, refreshToken }) => {
        await setAuthToken(accessToken)
        await setRefreshToken(refreshToken)
        router.replace('/dashboard')
      })
    }
  }, [token])

  return <LoadingScreen />
}
```

